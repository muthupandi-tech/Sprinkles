datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Used for non-pooled connections (Supabase)
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id // Corresponds to Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile            StudentProfile?
  progress           Progress?
  missions           DailyMission[]
  conversations      Conversation[]
  sessions           PracticeSession[]
  vocabularies       VocabularyProgress[]
  interviews         InterviewSession[]
  achievements       Achievement[]
  notifications      Notification[]
  learningPlans      LearningPlan[]
  speechAttempts     SpeechAttempt[]
  coachSuggestions   CoachSuggestion[]
  userVocabularies   UserVocabulary[]
  quizAttempts       VocabularyQuizAttempt[]
  gdSessions         GroupDiscussionSession[]
  
  @@map("users")
}

model StudentProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String?  @map("full_name")
  avatarUrl          String?  @map("avatar_url")
  college            String?
  department         String?
  yearOfStudy        String?  @map("year_of_study") // "1st Year", "2nd Year", etc.
  careerGoal         String?  @map("career_goal")
  targetCompany      String?  @map("target_company")
  englishProficiency String   @default("Beginner") @map("english_proficiency") // "Beginner", "Intermediate", "Advanced"
  preferredAccent    String   @default("American") @map("preferred_accent") // "American", "British", "Indian"
  dailyPracticeGoal  Int      @default(15) @map("daily_practice_goal") // in minutes
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("student_profiles")
}

model DailyMission {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  type        String // "vocabulary" | "speaking" | "pronunciation" | "interview"
  points      Int      @default(10)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("daily_missions")
}

model Progress {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak      Int      @default(0) @map("current_streak")
  overallScore       Float    @default(0.0) @map("overall_score") // 0-100 communication score
  speakingScore      Float    @default(0.0) @map("speaking_score")
  vocabularyScore    Float    @default(0.0) @map("vocabulary_score")
  pronunciationScore Float    @default(0.0) @map("pronunciation_score")
  interviewScore     Float    @default(0.0) @map("interview_score")
  gdScore            Float    @default(0.0) @map("gd_score")
  totalPracticeTime  Int      @default(0) @map("total_practice_time") // in minutes
  weeklyTimeHistory  Json     @map("weekly_time_history") // e.g. [15, 20, 10, 30, 0, 15, 25] for 7 days
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("progress_records")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  messages         Message[]
  coachSuggestions CoachSuggestion[]
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id") // Optional redundancy, or can just rely on conversation's userId
  role           String       // "user", "assistant", "system"
  content        String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("messages")
}

model PracticeSession {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String // "Speaking" | "Pronunciation" | "Vocabulary"
  durationMinutes Int      @map("duration_minutes")
  score           Int      @default(0)
  feedback        String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("practice_sessions")
}

model VocabularyProgress {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word         String
  definition   String?
  learned      Boolean  @default(false)
  masteryLevel Int      @default(0) @map("mastery_level") // e.g. 0-5
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("vocabulary_progress")
}

model InterviewSession {
  id             String              @id @default(uuid())
  userId         String              @map("user_id")
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        String              // "TCS", "Google", "Custom", etc.
  interviewType  String              // "HR", "Technical", "Behavioral", etc.
  resumeContext  String?             @db.Text // Extracted text from uploaded resume
  status         String              @default("in_progress") // "in_progress", "completed"
  overallScore   Int?                @map("overall_score")
  feedbackJson   Json?               @map("feedback_json") // High-level strengths, weaknesses, tips
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at")

  questions      InterviewQuestion[]

  @@map("interview_sessions")
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  iconName    String   @map("icon_name")
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  @@map("achievements")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model LearningPlan {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String
  description          String?   @db.Text
  tasksJson            Json      @map("tasks_json")
  status               String    @default("active") // "active", "completed", "archived"
  targetCompletionDate DateTime? @map("target_completion_date")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("learning_plans")
}

model SpeechAttempt {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcription      String   @db.Text
  targetText         String?  @map("target_text") @db.Text
  durationSeconds    Int      @map("duration_seconds")
  pronunciationScore Float    @map("pronunciation_score")
  fluencyScore       Float    @map("fluency_score")
  feedbackJson       Json     @map("feedback_json")
  audioUrl           String?  @map("audio_url")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("speech_attempts")
}

model CoachSuggestion {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String?       @map("conversation_id")
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  type           String        // "vocabulary" | "grammar" | "tip" | "challenge"
  content        String        @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("coach_suggestions")
}

model VocabularyWord {
  id               String   @id @default(uuid())
  word             String   @unique
  meaning          String   @db.Text
  pronunciation    String
  partOfSpeech     String
  synonyms         String[]
  antonyms         String[]
  exampleSentence  String   @db.Text
  interviewExample String?  @db.Text
  difficultyLevel  String   // "Beginner", "Intermediate", "Advanced"
  createdAt        DateTime @default(now()) @map("created_at")

  userVocabularies UserVocabulary[]

  @@map("vocabulary_words")
}

model UserVocabulary {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId       String         @map("word_id")
  word         VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  isBookmarked Boolean        @default(false)
  masteryLevel Int            @default(0) // 0-5
  nextReviewAt DateTime?      @map("next_review_at") // For Spaced Repetition
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@unique([userId, wordId])
  @@map("user_vocabularies")
}

model VocabularyQuizAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score          Int      
  totalQuestions Int
  quizData       Json     // Details of what was asked and answered
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("vocabulary_quiz_attempts")
}


model InterviewQuestion {
  id             String           @id @default(uuid())
  sessionId      String           @map("session_id")
  session        InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionText   String           @db.Text
  order          Int
  createdAt      DateTime         @default(now()) @map("created_at")

  answer         InterviewAnswer?

  @@map("interview_questions")
}

model InterviewAnswer {
  id                String            @id @default(uuid())
  questionId        String            @unique @map("question_id")
  question          InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswer     String            @db.Text
  grammarScore      Int
  fluencyScore      Int
  technicalAccuracy Int
  overallScore      Int
  feedbackJson      Json              @map("feedback_json") // Granular feedback, better sample answer
  createdAt         DateTime          @default(now()) @map("created_at")

  @@map("interview_answers")
}

model GroupDiscussionSession {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          String
  category       String         // "Campus Placement", "Technical", "Debate", etc.
  status         String         @default("in_progress") // "in_progress", "completed"
  overallScore   Int?           @map("overall_score")
  feedbackJson   Json?          @map("feedback_json")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")

  participants   GDParticipant[]
  messages       GDMessage[]

  @@map("gd_sessions")
}

model GDParticipant {
  id          String                 @id @default(uuid())
  sessionId   String                 @map("session_id")
  session     GroupDiscussionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name        String
  role        String                 // "Leader", "Supporter", "Critical Thinker", "Quiet Observer", "Challenger"
  avatarUrl   String?                @map("avatar_url")
  
  messages    GDMessage[]

  @@map("gd_participants")
}

model GDMessage {
  id             String                 @id @default(uuid())
  sessionId      String                 @map("session_id")
  session        GroupDiscussionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Either an AI participant or the user/moderator
  participantId  String?                @map("participant_id")
  participant    GDParticipant?         @relation(fields: [participantId], references: [id], onDelete: SetNull)
  
  speakerName    String                 // Cache the name for quick display
  speakerRole    String                 // "ai", "user", "moderator"
  content        String                 @db.Text
  createdAt      DateTime               @default(now()) @map("created_at")

  @@map("gd_messages")
}
